{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "description": "Validate JSON and back up data files after modifications",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/validate-data.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "description": "Create daily backup snapshot and session summary",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/session-end.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "description": "Display learner stats and check for due reviews",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/session-start.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "description": "Safety backup before conversation compaction",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/precompact-backup.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
