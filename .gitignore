# Personal learning data - DO NOT commit
# Catch-all: everything in data/ and results/ is private by default,
# whatever the file type (json, md, audio, backups...).
/data/*
/results/*
# Except the README files which explain the structure
!/data/README.md
!/results/README.md

# Personal writing/practice files
myfile.txt

# Backup files created by hooks
.backups/

# Keep directory structure but ignore contents
!/data/.gitkeep
!/results/.gitkeep

# System files
.DS_Store
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-*

# Python bytecode
__pycache__/
*.pyc

# Logs
*.log
npm-debug.log*

# Temp files
.tmp/
temp/
*.json.tmp


# Local TTS runtime (Kokoro) - never commit
.tts-venv/
.env*
